<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= process.env.APP_NAME %> OTP</title>
  </head>
  <body
    style="
      margin: 0;
      padding: 0;
      background-color: #edf1f7;
      font-family: Arial, Helvetica, sans-serif;
      color: #1f2a44;
    "
  >
    <table
      role="presentation"
      cellpadding="0"
      cellspacing="0"
      width="100%"
      style="background-color: #edf1f7; margin: 0; padding: 24px 0"
    >
      <tr>
        <td align="center">
          <table
            role="presentation"
            cellpadding="0"
            cellspacing="0"
            width="100%"
            style="max-width: 620px; margin: 0 auto"
          >
            <tr>
              <td style="padding: 0 16px">
                <table
                  role="presentation"
                  cellpadding="0"
                  cellspacing="0"
                  width="100%"
                  style="
                    background: #22356d;
                    border-radius: 24px 24px 0 0;
                    overflow: hidden;
                  "
                >
                  <tr>
                    <td style="padding: 28px 32px 18px 32px">
                      <div
                        style="
                          color: #ffffff;
                          font-size: 14px;
                          letter-spacing: 1.2px;
                          text-transform: uppercase;
                          opacity: 0.78;
                          margin-bottom: 10px;
                        "
                      >
                        <%= process.env.APP_NAME %>
                      </div>
                      <div
                        style="
                          color: #ffffff;
                          font-size: 30px;
                          line-height: 1.2;
                          font-weight: 700;
                          margin: 0 0 8px 0;
                        "
                      >
                        Your one-time code
                      </div>
                      <div
                        style="
                          color: #d9e3ff;
                          font-size: 15px;
                          line-height: 1.6;
                          margin: 0;
                        "
                      >
                        A clean, secure step to keep your account protected.
                      </div>
                    </td>
                  </tr>
                </table>

                <table
                  role="presentation"
                  cellpadding="0"
                  cellspacing="0"
                  width="100%"
                  style="
                    background: #ffffff;
                    border-radius: 0 0 24px 24px;
                    box-shadow: 0 18px 45px rgba(34, 53, 109, 0.12);
                  "
                >
                  <tr>
                    <td style="padding: 32px">
                      <table
                        role="presentation"
                        cellpadding="0"
                        cellspacing="0"
                        width="100%"
                        style="
                          background: #f7f9ff;
                          border: 1px solid #dde5fb;
                          border-radius: 18px;
                        "
                      >
                        <tr>
                          <td style="padding: 28px">
                            <div
                              style="
                                font-size: 18px;
                                line-height: 1.5;
                                font-weight: 600;
                                color: #1f2a44;
                                margin-bottom: 10px;
                              "
                            >
                              Hi <%= name %>,
                            </div>
                            <div
                              style="
                                font-size: 15px;
                                line-height: 1.8;
                                color: #56637a;
                                margin-bottom: 24px;
                              "
                            >
                              Use the verification code below to continue with
                              your <%= process.env.APP_NAME %> request.
                            </div>

                            <table
                              role="presentation"
                              cellpadding="0"
                              cellspacing="0"
                              width="100%"
                              style="
                                background: #ffffff;
                                border: 1px solid #d7e1fa;
                                border-radius: 16px;
                              "
                            >
                              <tr>
                                <td align="center" style="padding: 24px 16px">
                                  <div
                                    style="
                                      font-size: 12px;
                                      line-height: 1;
                                      font-weight: 700;
                                      letter-spacing: 1.6px;
                                      text-transform: uppercase;
                                      color: #7d8db3;
                                      margin-bottom: 14px;
                                    "
                                  >
                                    Verification Code
                                  </div>
                                  <div
                                    style="
                                      font-size: 34px;
                                      line-height: 1.1;
                                      font-weight: 700;
                                      letter-spacing: 10px;
                                      color: #22356d;
                                    "
                                  >
                                    <%= otp %>
                                  </div>
                                </td>
                              </tr>
                            </table>

                            <div
                              style="
                                margin-top: 24px;
                                font-size: 14px;
                                line-height: 1.8;
                                color: #56637a;
                              "
                            >
                              This code expires in a few minutes and should only
                              be used once. If you did not request this, you can
                              safely ignore this email.
                            </div>
                          </td>
                        </tr>
                      </table>

                      <div
                        style="
                          margin-top: 24px;
                          font-size: 13px;
                          line-height: 1.8;
                          color: #7b879c;
                          text-align: center;
                        "
                      >
                        Secure access for every action inside
                        <strong style="color: #22356d"
                          ><%= process.env.APP_NAME %></strong
                        >
                      </div>
                    </td>
                  </tr>
                </table>
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
