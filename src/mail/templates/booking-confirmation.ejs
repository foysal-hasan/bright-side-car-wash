<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Booking Confirmation</title>
</head>
<body style="margin: 0; padding: 0; background: #f8fafc; font-family: Arial, sans-serif; color: #0f172a;">
  <table role="presentation" cellpadding="0" cellspacing="0" width="100%" style="background: #f8fafc; padding: 24px 0;">
    <tr>
      <td align="center">
        <table role="presentation" cellpadding="0" cellspacing="0" width="100%" style="max-width: 640px; background: #ffffff; border-radius: 10px; border: 1px solid #e2e8f0; overflow: hidden;">
          <tr>
            <td style="background: #0f766e; padding: 18px 24px; color: #ffffff; font-size: 22px; font-weight: 700;">
              Booking Confirmed
            </td>
          </tr>
          <tr>
            <td style="padding: 24px;">
              <p style="margin: 0 0 14px; font-size: 16px; line-height: 1.6;">
                Hi <strong><%= customerName %></strong>,
              </p>
              <p style="margin: 0 0 14px; font-size: 15px; line-height: 1.7;">
                Your booking has been successfully confirmed with <strong><%= appName %></strong>.
              </p>

              <table role="presentation" cellpadding="0" cellspacing="0" width="100%" style="margin: 12px 0 16px; border: 1px solid #e2e8f0; border-radius: 8px;">
                <tr>
                  <td style="padding: 12px 14px; border-bottom: 1px solid #e2e8f0; width: 38%; color: #334155;">Booking ID</td>
                  <td style="padding: 12px 14px; border-bottom: 1px solid #e2e8f0; font-weight: 600;"><%= bookingId %></td>
                </tr>
                <tr>
                  <td style="padding: 12px 14px; border-bottom: 1px solid #e2e8f0; color: #334155;">Appointment Time</td>
                  <td style="padding: 12px 14px; border-bottom: 1px solid #e2e8f0; font-weight: 600;"><%= startAt %></td>
                </tr>
                <tr>
                  <td style="padding: 12px 14px; color: #334155;">Paid Amount</td>
                  <td style="padding: 12px 14px; font-weight: 600;"><%= currency %> <%= totalAmount %></td>
                </tr>
              </table>

              <p style="margin: 0 0 8px; font-size: 15px; font-weight: 600;">Services</p>
              <ul style="margin: 0 0 16px 20px; padding: 0; color: #1e293b;">
                <% if (services && services.length) { %>
                  <% services.forEach(function(service) { %>
                    <li style="margin: 0 0 6px;"><%= service %></li>
                  <% }); %>
                <% } else { %>
                  <li style="margin: 0 0 6px;">Online Booking Service</li>
                <% } %>
              </ul>

              <p style="margin: 0; font-size: 14px; line-height: 1.7; color: #475569;">
                Please keep this email for your records. If you need to reschedule or have questions, reply to this email.
              </p>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>
