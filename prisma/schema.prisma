//   textContent String   // The raw message text limits (e.g., max 160 chars)
// }

// ===================== Templetes end =====================

// ===================== Email Logs start =====================
enum EmailStatus {
  DELIVERED
  PENDING
  FAILED
  BOUNCED
}

model EmailLog {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  
  sender_name  String?
  sender_mail  String
  to          String   
  cc          String[] @default([]) 
  bcc         String[] @default([]) 
  subject     String
  body        String   @db.Text
  files       String[] @default([])
  status      EmailStatus @default(PENDING)
  is_opened   Boolean  @default(false)
  is_clicked  Boolean  @default(false)

  // extranal provider's email ID for tracking
  provider_email_id String? @unique

  // Optional connection to a Lead
  leadId      String?
  lead        Lead?    @relation("LeadEmailLogs", fields: [leadId], references: [id], onDelete: SetNull)

  // Tracker for which Staff/User created this email
  created_by_id String?
  creator       User?    @relation("SentEmails", fields: [created_by_id], references: [id], onDelete: SetNull)

  @@index([to])
  @@index([leadId])
  @@index([created_by_id])
  @@map("email_logs")
}

// ===================== Email Logs end =====================

// ===================== FAQ start =====================
model Faq {
  id            String   @id @default(cuid())
  question      String   @db.Text
  answer        String   @db.Text
  display_order Int      @default(0)
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now()) @db.Timestamptz
  updated_at    DateTime @updatedAt @db.Timestamptz

  @@index([is_active, display_order])
  @@map("faqs")
}
// ==================== FAQ end =====================

// ==================== Gallery start =====================
model Gallery {
  id         String   @id @default(cuid())
  name       String   @db.VarChar(255)
  image      String   
  created_at DateTime @default(now()) @db.Timestamptz
  updated_at DateTime @updatedAt @db.Timestamptz

  @@map("galleries")
}
// ==================== Gallery end =====================

// ==================== Testimonial start =====================
model Testimonial {
  id          String   @id @default(cuid())
  avatar      String?  
  name        String
  designation String
  review_text  String   @db.Text
  ratings     Int      @default(5)
  is_active    Boolean  @default(true)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  @@map("testimonials")
}
// ================== Testimonial end =====================

// =================== News and Events start =====================
model Category {
  id              String         @id @default(cuid())
  name            String         @unique
  slug            String         @unique
  created_at      DateTime       @default(now()) @db.Timestamptz
  updated_at      DateTime       @updatedAt @db.Timestamptz
  news_and_events NewsAndEvent[]

  @@map("categories")
}

model NewsAndEvent {
  id           String   @id @default(cuid())
  title        String
  slug         String   @unique
  content      String   @db.Text
  summary      String?  @db.Text
  image_url    String?
  category_id  String
  is_published Boolean  @default(false)
  created_at   DateTime @default(now()) @db.Timestamptz
  updated_at   DateTime @updatedAt @db.Timestamptz

  category Category @relation(fields: [category_id], references: [id], onDelete: Restrict)

  created_by_id String
  creator  User     @relation(fields: [created_by_id], references: [id], onDelete: Cascade)

  @@map("news_and_events")
}
// =================== News and Events end =====================

// =================== Notification start =====================
enum NotificationChannel {
  EMAIL
  SMS
  PUSH
  IN_APP
}

enum NotificationStatus {
  PENDING
  SUCCESS
  FAILED
}

model NotificationLog {
  id         String              @id @default(uuid())
  recipient  String
  title      String
  body       String
  channel    NotificationChannel
  status     NotificationStatus  @default(PENDING)
  metadata   Json?
  error_logs String?             @db.Text
  created_at DateTime            @default(now())
  updated_at DateTime            @updatedAt

  @@map("notification_logs")
}

// =================== Notification end =====================