// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider     = "prisma-client"
  // output   = "./generated"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id         String   @id @default(cuid())
  created_at DateTime @default(now())
  updated_at DateTime @default(now())

  user_id String
  user    User   @relation(fields: [user_id], references: [id], onDelete: Cascade)

  type                String?
  provider            String?
  provider_account_id String?
  refresh_token       String?
  access_token        String?
  expires_at          DateTime?
  token_type          String?
  scope               String?
  id_token            String?
  session_state       String?

  @@unique([provider, provider_account_id])
  @@map("accounts")
}

model User {
  id           String    @id @default(cuid())
  created_at   DateTime  @default(now())
  updated_at   DateTime  @default(now())
  deleted_at   DateTime?
  status       Int?      @default(1) @db.SmallInt
  approved_at  DateTime?
  availability String?

  // Authentication fields
  email        String? @unique
  username     String? @unique
  password     String? @db.VarChar(255)
  phone_number String?

  // Personal info
  name          String?   @db.VarChar(255)
  first_name    String?   @db.VarChar(255)
  last_name     String?   @db.VarChar(255)
  avatar        String?
  gender        String?
  date_of_birth DateTime? @db.Date

  // Location
  country  String?
  state    String?
  city     String?
  address  String?
  zip_code String?
  domain   String? @unique

  // Verification & billing
  email_verified_at   DateTime?
  billing_id          String?
  stripeAccountId     String?   @unique
  onboardingCompleted Boolean   @default(false)
  type                String? // Consider changing to enum

  // Two-factor auth
  is_two_factor_enabled Int?     @default(0)
  two_factor_secret     String?
  isPhoneVerified       Boolean? @default(false)

  // Invitation & referral
  isActive          Boolean   @default(false)
  inviteToken       String? // Hashed token
  inviteTokenExpiry DateTime?

  // Other relations
  accounts                     Account[]
  ucodes                       Ucode[]
  userSessions                 UserSession[]
  messages                     Message[]              @relation("receiver")
  sent_messages                Message[]              @relation("sender")
  conversations_created        Conversation[]         @relation("creator")
  conversations_as_participant Conversation[]         @relation("participant")
  roleUsers                    RoleUser[]
  activityLogs                 ActivityLog[]
  lead_activity_timelines      LeadActivityTimeline[]
  created_leads                Lead[]                 @relation("CreatedLeads")
  assigned_leads               Lead[]                 @relation("AssignedLeads")
  emailLogs                    EmailLog[]             @relation("SentEmails")

  assignment_history             LeadAssignmentHistory[] @relation("LeadAssignee")
  assignment_history_as_assigner LeadAssignmentHistory[] @relation("LeadAssigner")

  // relations for news and events
  news_and_events_created NewsAndEvent[]

  @@index([email])
  @@index([phone_number])
  @@map("users")
}

model UserSession {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceName String
  ipAddress  String
  expiresAt  DateTime
}

model Ucode {
  id         String   @id @default(cuid())
  created_at DateTime @default(now())
  updated_at DateTime @default(now())
  status     Int?     @default(1) @db.SmallInt

  user_id String?
  user    User?   @relation(fields: [user_id], references: [id])

  token        String?
  email        String?
  phone_number String?
  expired_at   DateTime?

  @@map("ucodes")
}

// Add the dynamic Role model
model Role {
  id          String   @id @default(cuid())
  name        String   @unique // e.g., "Content Manager", "Support Tier 2"
  description String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  users       RoleUser[]
  permissions RolePermission[]

  @@map("roles")
}

// Add the granular Permission model (The "atoms" of system actions)
model Permission {
  id          String   @id @default(cuid())
  name        String   @unique // e.g., "users:create", "billing:refund", "posts:delete"
  description String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  roles RolePermission[]

  @@map("permissions")
}

// Join Table: Maps Users to Roles
model RoleUser {
  user_id String
  role_id String
  user    User   @relation(fields: [user_id], references: [id], onDelete: Cascade)
  role    Role   @relation(fields: [role_id], references: [id], onDelete: Cascade)

  @@id([user_id, role_id])
  @@map("role_users")
}

// Join Table: Maps Roles to Permissions
model RolePermission {
  role_id       String
  permission_id String
  role          Role       @relation(fields: [role_id], references: [id], onDelete: Cascade)
  permission    Permission @relation(fields: [permission_id], references: [id], onDelete: Cascade)

  @@id([role_id, permission_id])
  @@map("role_permissions")
}

enum MessageStatus {
  PENDING
  SENT
  DELIVERED
  READ
}

// message is used for conversation
model Message {
  id         String    @id @default(cuid())
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now())
  deleted_at DateTime?

  status MessageStatus? @default(PENDING)

  sender_id String?
  sender    User?   @relation("sender", fields: [sender_id], references: [id])

  receiver_id String?
  receiver    User?   @relation("receiver", fields: [receiver_id], references: [id])

  conversation_id String?
  conversation    Conversation? @relation(fields: [conversation_id], references: [id], onDelete: Cascade)

  attachment_id String?
  attachment    Attachment? @relation(fields: [attachment_id], references: [id])

  message String?

  @@map("messages")
}

// this table stores attachment of message
model Attachment {
  id         String    @id @default(cuid())
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now())
  deleted_at DateTime?

  name     String?
  type     String?
  size     Int?
  file     String?
  file_alt String?

  messages Message[]

  @@map("attachments")
}

// this table stores conversation
model Conversation {
  id         String    @id @default(cuid())
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now())
  deleted_at DateTime?

  creator_id String?
  creator    User?   @relation("creator", fields: [creator_id], references: [id])

  participant_id String?
  participant    User?   @relation("participant", fields: [participant_id], references: [id])

  messages Message[]

  @@map("conversations")
}

// ---------End Chat schema---------

model SocialMedia {
  id         String    @id @default(cuid())
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now())
  deleted_at DateTime?

  status     Int?    @default(1) @db.SmallInt
  sort_order Int?    @default(0)
  name       String?
  url        String?
  icon       String?

  @@map("social_media")
}

model WebsiteInfo {
  id         String    @id @default(cuid())
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now())
  deleted_at DateTime?

  name                String?
  phone_number        String?
  email               String?
  address             String?
  logo                String?
  favicon             String?
  copyright           String?
  cancellation_policy String?

  @@map("website_info")
}

model ActivityLog {
  id          String   @id @default(cuid())
  action      String // e.g., "CREATE", "UPDATE", "DELETE", "LOGIN", "LOGOUT"
  entity      String // e.g., "User", "Product", "Order"
  entityId    String?  @map("entity_id") // ID of the affected entity
  changes     Json? // Store before/after values for updates
  metadata    Json? // Additional context (IP, user agent, etc.)
  description String? // Human-readable description
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Optional relation to User who performed the action
  userId String? @map("user_id")
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([entity])
  @@index([createdAt(sort: Desc)])
  @@map("activity_logs")
}

model Stage {
  id         String    @id @default(cuid())
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now())
  deleted_at DateTime?

  name       String  @unique
  sort_order Int?    @default(0)
  color      String?
  icon       String?

  // Add a relation to Lead
  leads Lead[]

  @@index([name])
  @@map("stages")
}

enum DepositStatus {
  PENDING
  PAID
  REFUNDED
  FAILED
}

enum LeadPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Lead {
  id         String    @id @default(cuid())
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now())
  deleted_at DateTime?

  name           String?
  email          String? @unique
  phone          String?
  service        String?
  vehicle        String?
  source         String?
  deposit_status DepositStatus? @default(PENDING)
  priority       LeadPriority?  @default(LOW)
  notes          String[]       @default([])

  deposit_amount   Decimal?       @db.Decimal(10, 2) @default(0.00)
  deposit_currency String?        @default("USD")

  // attachments 
  attachments String[] @default([])

  // Relation to Stage
  stage_id String?
  stage    Stage?  @relation(fields: [stage_id], references: [id]) 

  // Relation to LeadActivityTimeline
  activity_timelines LeadActivityTimeline[]

  // Optional relation to User who created the lead
  created_by_id String?
  creator       User?   @relation("CreatedLeads", fields: [created_by_id], references: [id], onDelete: SetNull)

  // Relation to User (assigned_to)
  assigned_to_id String?
  assignee       User?   @relation("AssignedLeads", fields: [assigned_to_id], references: [id], onDelete: SetNull)

  // Relation to LeadAssignmentHistory
  assignment_history LeadAssignmentHistory[]
  // Implicit Many-to-Many connection
  leadGroups         LeadGroup[]             @relation("LeadToGroup")

  // Relation to EmailLog
  emailLogs          EmailLog[]              @relation("LeadEmailLogs")

  // Relation to Payment
  payments           Payment[]

  @@index([email])
  @@map("leads")
}

model LeadAssignmentHistory {
  id         String    @id @default(cuid())
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now()) @updatedAt
  deleted_at DateTime?

  lead_id String
  lead    Lead   @relation(fields: [lead_id], references: [id], onDelete: Cascade)

  // Added distinct relation names "LeadAssignee" and "LeadAssigner"
  assigned_to_id String?
  assignee       User?   @relation("LeadAssignee", fields: [assigned_to_id], references: [id], onDelete: SetNull)

  assigned_by_id String?
  assigner       User?   @relation("LeadAssigner", fields: [assigned_by_id], references: [id], onDelete: SetNull)

  @@index([lead_id])
  @@map("lead_assignment_history")
}

model LeadActivityTimeline {
  id         String    @id @default(cuid())
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now())
  deleted_at DateTime?

  lead_id String
  lead    Lead   @relation(fields: [lead_id], references: [id], onDelete: Cascade)

  description String?
  source      String?

  user_id String?
  user    User?   @relation(fields: [user_id], references: [id], onDelete: SetNull)

  @@index([lead_id])
  @@map("lead_activity_timelines")
}


// ==================== Payments Start ====================
enum PaymentStatus {
  PENDING
  PAID
  REFUNDED
  FAILED
}

model Payment {
  id             String        @id @default(cuid())
  transaction_id String        @unique @map("transaction_id")
  customer_name  String?       @map("customer_name")
  service        String?       
  

  amount         Decimal       @db.Decimal(10, 2)
  currency       String        @default("USD")
  status         PaymentStatus @default(PENDING)
  
  created_at     DateTime      @default(now()) 
  updated_at     DateTime      @updatedAt

  lead_id        String?       @map("lead_id")
  lead           Lead?         @relation(fields: [lead_id], references: [id], onDelete: SetNull)

  @@index([lead_id])
  @@index([status])
  @@map("payments")
}
// ==================== Payments End ====================

// ==================== Campaign Management Start ====================

enum CampaignStatus {
  DRAFT
  SCHEDULED
  RUNNING
  COMPLETED
  FAILED
  SUSPENDED
}

enum ChannelType {
  EMAIL
  // SMS
}

enum DeliveryStatus {
  PENDING
  SENT
  DELIVERED
  OPENED
  CLICKED
  BOUNCED
  FAILED
}

// 1. Core Campaign Metadata Table
model Campaign {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name        String // Internal reference name
  tags       String[] @default([])
  status      CampaignStatus @default(DRAFT)
  channelType ChannelType
  scheduledAt DateTime?      @db.Timestamptz

  // Relationships
  emailConfig  EmailConfig? // One-to-One mapping for Email details
  // smsConfig    SmsConfig?     // One-to-One mapping for SMS details
  deliveryLogs DeliveryLog[] // One-to-Many tracking for metrics

  @@index([status])
  @@index([channelType])
}


// 2. Extensible Email-Specific Configurations
model EmailConfig {
  id         String   @id @default(cuid())
  campaignId String   @unique
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  subject       String
  htmlContent   String
  senderName    String
  senderEmail   String
  targetListIds Int[] // Array of provider list IDs (e.g., Brevo lists [2, 4])

  // Storing the ID generated by Brevo/Mailgun to tie webhooks back to this schema
  providerCampaignId String? @unique

  // Relationships
  templateId String? // Optional link to a saved template
  template   Template? @relation(fields: [templateId], references: [id])

  // Link directly to a target segment group
  leadGroupId String
  leadGroup   LeadGroup @relation(fields: [leadGroupId], references: [id])
}

// // 3. Extensible SMS-Specific Configurations
// model SmsConfig {
//   id                 String   @id @default(cuid())
//   campaignId         String   @unique
//   campaign           Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

//   senderId           String   // e.g., "MYBRAND" or a Twilio Phone Number
//   textContent        String
//   targetSegmentIds   String[] // Target user filters or phone list arrays

//   providerCampaignId String?  @unique
// }

// 4. Agnostic Unified Analytics & Webhook Event Logs
model DeliveryLog {
  id         String   @id @default(cuid())
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  recipient       String // Email address or Phone number
  status          DeliveryStatus @default(PENDING)
  providerEventId String? // The tracking ID sent by Brevo/Twilio's webhook

  // Metadata JSON captures unique vendor data (e.g., IP address, user-agent) 
  // without altering your hard columns.
  metaData Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([campaignId])
  @@index([recipient])
  @@index([status])
  @@index([campaignId, recipient])
  @@map("delivery_logs")
}

model LeadGroup {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  name        String
  description String?

  // Store the single Brevo list ID for reuse
  brevoListId Int? 

  // Relationships
  leads         Lead[]        @relation("LeadToGroup")
  emailCampaigns EmailConfig[]

  @@map("lead_groups")
}

// ==================== Campaign Management End ====================

// ===================== Templetes start =====================
enum TemplateType {
  EMAIL
}

enum EditorType {
  VISUAL_DRAG_DROP // For block-based builders
  RAW_HTML // For custom developers
  PLAIN_TEXT // Primarily for SMS or simple emails
}

// 1. Template Master Table
model Template {
  id          String       @id @default(cuid())
  name        String // e.g., "Black Friday Warmup - Version 2"
  description String?
  type        TemplateType @default(EMAIL)
  editorType  EditorType   @default(VISUAL_DRAG_DROP)

  // Scoping fields (Allows multi-tenant/user-specific custom lists)
  userId     String? // Nullable means it's a "System/Global Template" for everyone
  isArchived Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Channel Configurations
  emailBody EmailTemplate? // Structured data if type is EMAIL
  // smsBody        SmsTemplate?    // Structured data if type is SMS

  // Relationships back to campaigns
  emailCampaigns EmailConfig[] // Reuse tracking

  @@index([userId])
  @@index([type])
  @@index([isArchived])
}

// 2. Specialized Email Template Layer
model EmailTemplate {
  id         String   @id @default(cuid())
  templateId String   @unique
  template   Template @relation(fields: [templateId], references: [id], onDelete: Cascade)

  subject     String? // Default subject line pre-saved with layout
  htmlContent String // The compiled, web-ready HTML code

  // If your dashboard uses a drag-and-drop builder (like MJML or Unlayer), 
  // you must save the JSON structural state so users can reload and edit blocks later.
  designJson Json?
}

